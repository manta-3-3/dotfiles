alias home='cd ~'

# docker compose
alias dcols='(cd /opt/dockge && docker compose ls -a)'
alias dcoc='docker compose config'
alias dcou='docker compose up --build -d'
alias dcol='docker compose logs'
alias dcop='docker compose pull'
alias dcod='docker compose down'

# docker
alias dexec='docker exec -it'
alias dlogs='docker logs'
alias dps='docker ps -a --format "table {{ "{{" }}.ID{{ "}}" }}\t{{ "{{" }}.Names{{ "}}" }}\t{{ "{{" }}.Image{{ "}}" }}\t{{ "{{" }}.Status{{ "}}" }}"'

# ssh
alias skf='ssh-add -D && echo "All SSH-Keys removed."'
alias sks='ssh-add -l'
